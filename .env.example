# Q-agent — Credentials & API keys
#
# Copy this file to `.env` (gitignored) and fill in your own values.
# Pipelines and tools read these via os.environ or dotenv loaders.
#
# Most pipelines also accept profile/config files in their own subdirectory;
# see CREDENTIALS.md at the repo root for the full reference.

# --- SEC EDGAR ---------------------------------------------------------------
# Required by infrastructure/pipelines/edgar/pipeline.py.
# SEC requires a real user-agent identifying the operator. Use your own name
# and a reachable email. SEC may rate-limit or block the placeholder pattern.
SEC_EDGAR_IDENTITY="Your Name your.email@example.com"

# --- WRDS (Wharton Research Data Services) -----------------------------------
# Used by infrastructure/pipelines/wrds/. Alternative to ~/.pgpass.
# You also need an account from your institution (WRDS access is paid).
# Configure named profiles in infrastructure/pipelines/wrds/.wrds_profiles.json.
WRDS_USERNAME=
WRDS_PASSWORD=
WRDS_PROFILE=  # optional: name of profile from .wrds_profiles.json

# --- Crypto exchanges --------------------------------------------------------
# Used by infrastructure/pipelines/crypto/. Public OHLCV endpoints work without
# keys; only set these if you need authenticated/rate-limit-elevated access.
# See infrastructure/pipelines/crypto/.env.example for the full set.
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Polymarket --------------------------------------------------------------
# Used by infrastructure/pipelines/polymarket/. Read-only endpoints (Gamma,
# CLOB price history) require no auth. Only set these if you need trading or
# authenticated CLOB endpoints.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# --- agent_graph_system: Neo4j ----------------------------------------------
# Used by agent_graph_system/. Required when using the Neo4j backend
# (omit if using the local in-memory engine).
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=  # do NOT use "password" in production

# --- agent_graph_system: GitHub ingestion -----------------------------------
# Used by agent_graph_system/ingestion/github/ to fetch repo metadata.
# Personal access token with `repo` (or `public_repo`) scope.
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_REPOS=wolfpackofone/q-agent  # comma-separated owner/repo list

# --- Marimo notebooks --------------------------------------------------------
# Optional. Used by .claude/skills/marimo-pair/ to authenticate to a running
# marimo kernel. Only needed if you've started marimo with --token.
MARIMO_TOKEN=

# --- QuantConnect (cloud backtests via lean CLI) -----------------------------
# Optional. Stored separately by `lean login` in ~/.lean/credentials.
# Set these only if you want to bootstrap lean CLI from env vars instead of
# the interactive login.
QC_USER_ID=
QC_API_TOKEN=
