# QuantConnect project .gitignore

# Project config (contains organization-id, cloud-id)
config.json

# Backtest results (regeneratable)
backtests/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment
.env
.env.local
*.local

# Secrets (never commit these)
*token*
*secret*
*password*
*credential*
*.pem
*.key
